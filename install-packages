#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BREW_BIN="/opt/homebrew/bin/brew"

if [[ ! -x "$BREW_BIN" ]]; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

echo "Installing packages from Brewfile..."
"$BREW_BIN" bundle --file "$ROOT_DIR/Brewfile"

ZSH_SITE_FUNCTIONS="$HOME/.local/share/zsh/site-functions"

if command -v docker >/dev/null 2>&1; then
  echo "Installing Docker zsh completions..."
  mkdir -p "$ZSH_SITE_FUNCTIONS"
  docker completion zsh > "$ZSH_SITE_FUNCTIONS/_docker"
fi
