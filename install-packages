#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BREW_BIN="/opt/homebrew/bin/brew"
DOCKER_APP="/Applications/Docker.app"
DOCKER_BIN="/usr/local/bin/docker"
ZSH_SITE_FUNCTIONS="$HOME/.local/share/zsh/site-functions"

installer_file=""
completion_file=""

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

cleanup() {
  if [[ -n "$installer_file" ]]; then
    rm -f "$installer_file"
  fi

  if [[ -n "$completion_file" ]]; then
    rm -f "$completion_file"
  fi
}

trap cleanup EXIT

if [[ "$#" -ne 0 ]]; then
  die "install-packages does not accept arguments"
fi

if [[ "$(uname -s)" != "Darwin" ]]; then
  die "install-packages only supports macOS"
fi

if [[ "$(uname -m)" != "arm64" ]]; then
  die "install-packages only supports Apple Silicon"
fi

if [[ "$EUID" -eq 0 || -n "${SUDO_USER:-}" ]]; then
  die "run install-packages as the target user, without sudo"
fi

if [[ ! -r "$ROOT_DIR/Brewfile" ]]; then
  die "Brewfile is not readable: $ROOT_DIR/Brewfile"
fi

if [[ -d "$DOCKER_APP" && ! -x "$DOCKER_BIN" ]]; then
  die "Docker Desktop is installed but $DOCKER_BIN is not executable"
fi

if [[ ! -x "$BREW_BIN" ]]; then
  echo "Installing Homebrew..."
  installer_file="$(mktemp -t homebrew-install.XXXXXX)"
  /usr/bin/curl --fail --silent --show-error --location \
    --output "$installer_file" \
    https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh

  if [[ ! -s "$installer_file" ]]; then
    die "downloaded Homebrew installer is empty"
  fi

  /bin/bash "$installer_file"
  rm -f "$installer_file"
  installer_file=""
fi

if [[ ! -x "$BREW_BIN" ]]; then
  die "Homebrew is not executable after installation: $BREW_BIN"
fi

echo "Installing packages from Brewfile..."
"$BREW_BIN" bundle install --file "$ROOT_DIR/Brewfile" --jobs auto

if [[ -d "$DOCKER_APP" ]]; then
  echo "Installing Docker zsh completions..."
  mkdir -p "$ZSH_SITE_FUNCTIONS"
  completion_file="$(mktemp "$ZSH_SITE_FUNCTIONS/.docker.XXXXXX")"

  if ! "$DOCKER_BIN" completion zsh >"$completion_file"; then
    die "Docker zsh completion generation failed"
  fi

  if [[ ! -s "$completion_file" ]]; then
    die "Docker generated an empty zsh completion"
  fi

  chmod 0644 "$completion_file"
  mv -f "$completion_file" "$ZSH_SITE_FUNCTIONS/_docker"
  completion_file=""
fi
