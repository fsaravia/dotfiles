#!/usr/bin/env bash

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "cleanup-home only supports macOS"
  exit 1
fi

DRY_RUN=false
YES=false

case "${1:-}" in
  --dry-run)
    DRY_RUN=true
    ;;
  --yes)
    YES=true
    ;;
  "")
    ;;
  *)
    echo "usage: $0 [--dry-run|--yes]"
    exit 1
    ;;
esac

timestamp="$(date +"%Y%m%d-%H%M%S")"
backup_dir="$HOME/.dotfiles-cleanup-backups/$timestamp"

run() {
  if [[ "$DRY_RUN" == true ]]; then
    printf 'dry-run:'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@"
  fi
}

exists_or_link() {
  [[ -e "$1" || -L "$1" ]]
}

remove_path() {
  local path="$1"

  if exists_or_link "$path"; then
    echo "removing $path"
    if [[ "$DRY_RUN" == true ]]; then
      run rm -rf "$path"
    elif ! rm -rf "$path"; then
      echo "warning: could not fully remove $path"
    fi
  fi
}

remove_symlink() {
  local path="$1"

  if [[ -L "$path" ]]; then
    echo "removing $path"
    if [[ "$DRY_RUN" == true ]]; then
      run rm "$path"
    else
      rm "$path"
    fi
  elif [[ -e "$path" ]]; then
    echo "leaving real file $path"
  fi
}

copy_file() {
  local source="$1"
  local destination="$2"

  if [[ ! -f "$source" ]]; then
    return
  fi

  run mkdir -p "$(dirname "$destination")"

  if [[ -f "$destination" && "$DRY_RUN" == false ]] && ! cmp -s "$source" "$destination"; then
    mkdir -p "$backup_dir"
    cp -p "$destination" "$backup_dir/$(basename "$destination")"
    echo "backed up existing $destination to $backup_dir"
  fi

  echo "copying $source -> $destination"
  run cp -p "$source" "$destination"
}

append_file() {
  local source="$1"
  local destination="$2"

  if [[ ! -f "$source" ]]; then
    return
  fi

  run mkdir -p "$(dirname "$destination")"
  echo "appending $source -> $destination"

  if [[ "$DRY_RUN" == true ]]; then
    printf 'dry-run: cat %q >> %q\n' "$source" "$destination"
  else
    cat "$source" >> "$destination"
  fi
}

if [[ "$YES" != true && "$DRY_RUN" != true ]]; then
  echo "This will remove generated caches, stale dotfile paths, and orphaned app data from $HOME."
  read -r -p "Continue? [y/N] " answer

  case "$answer" in
    y|Y|yes|YES)
      ;;
    *)
      echo "aborted"
      exit 1
      ;;
  esac
fi

echo "Migrating old dotfile state..."
copy_file "$HOME/.gitconfig.local" "$HOME/.config/git/config.local"
append_file "$HOME/.zsh_history" "$HOME/.local/state/zsh/history"

remove_symlink "$HOME/.gitconfig"
remove_symlink "$HOME/.gitignore"
remove_path "$HOME/.gitconfig.local"
remove_path "$HOME/.zsh_history"
remove_path "$HOME/.zcompcache"

echo "Removing generated caches..."
remove_path "$HOME/Library/Containers/com.apple.podcasts/Data/tmp/StreamedMedia"
run mkdir -p "$HOME/Library/Containers/com.apple.podcasts/Data/tmp/StreamedMedia"

remove_path "$HOME/.npm"
remove_path "$HOME/.cache/puppeteer"
remove_path "$HOME/Library/Caches/trivy"
remove_path "$HOME/Library/Caches/Google"
remove_path "$HOME/Library/Caches/com.anthropic.claudefordesktop.ShipIt"
remove_path "$HOME/Library/Caches/node-gyp"
remove_path "$HOME/Library/Caches/typescript"
remove_path "$HOME/Library/Caches/cursor-compile-cache"
remove_path "$HOME/Library/Caches/loom-updater"
remove_path "$HOME/Library/Caches/@slitedesktop-updater"
remove_path "$HOME/Library/Caches/com.hnc.Discord.ShipIt"
remove_path "$HOME/Library/Caches/com.openai.chat"
remove_path "$HOME/Library/Caches/Homebrew"
remove_path "$HOME/Library/Caches/com.apple.callintelligenced"
remove_path "$HOME/Library/Caches/com.apple.textunderstandingd"
remove_path "$HOME/Library/Caches/SiriTTS"
remove_path "$HOME/Library/Caches/com.apple.Music"
remove_path "$HOME/Library/Caches/pip"
remove_path "$HOME/Library/Caches/com.apple.python"

remove_path "$HOME/Library/Application Support/Google/Chrome/OptGuideOnDeviceModel"
remove_path "$HOME/Library/Application Support/Google/GoogleUpdater/crx_cache"
remove_path "$HOME/Library/Application Support/Google/Chrome/component_crx_cache"
remove_path "$HOME/Library/Application Support/Google/Chrome/optimization_guide_model_store"
remove_path "$HOME/Library/Application Support/Google/Chrome/screen_ai"
remove_path "$HOME/Library/Application Support/Google/Chrome/WasmTtsEngine"

remove_path "$HOME/Downloads/Codex.dmg"

echo "Removing orphaned app support..."
remove_path "$HOME/Library/Application Support/TabNine"
remove_path "$HOME/Library/Application Support/GitKrakenCLI"
remove_path "$HOME/Library/Application Support/Arc"
remove_path "$HOME/Library/Application Support/Chromium"
remove_path "$HOME/Library/Application Support/Microsoft Edge"
remove_path "$HOME/Library/Application Support/Microsoft Edge Beta"
remove_path "$HOME/Library/Application Support/Microsoft Edge Canary"
remove_path "$HOME/Library/Application Support/Microsoft Edge Dev"
remove_path "$HOME/Library/Application Support/Mozilla"
remove_path "$HOME/Library/Application Support/Vivaldi"
remove_path "$HOME/Library/Application Support/Vivaldi Snapshot"
remove_path "$HOME/Library/Application Support/balena-etcher"
remove_path "$HOME/Library/Application Support/Cisco Spark"
remove_path "$HOME/Library/Group Containers/group.com.flightyapp.flighty"
remove_path "$HOME/Library/Group Containers/JLMPQHK86H.com.culturedcode.ThingsMac"

if command -v go >/dev/null 2>&1; then
  echo "cleaning Go build cache"
  run go clean -cache
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
  echo "cleaning Homebrew"
  run /opt/homebrew/bin/brew cleanup -s
fi

echo "Done."
