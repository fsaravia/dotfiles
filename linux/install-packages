#!/usr/bin/env bash

set -euo pipefail

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

if [[ "$#" -ne 0 ]]; then
  die "linux/install-packages does not accept arguments"
fi

if [[ "$(uname -s)" != "Linux" ]]; then
  die "linux/install-packages only supports Linux"
fi

if [[ -n "${SUDO_USER:-}" ]]; then
  die "run linux/install-packages as the target user, without sudo"
fi

if [[ ! -r /etc/os-release ]]; then
  die "/etc/os-release is required"
fi

# shellcheck source=/dev/null
source /etc/os-release

case "${ID:-}:${VERSION_ID:-}" in
  debian:13 | ubuntu:24.04 | ubuntu:26.04) ;;
  *)
    die "supported systems are Debian 13, Ubuntu 24.04, and Ubuntu 26.04"
    ;;
esac

if ! LC_ALL=C.UTF-8 /usr/bin/locale charmap >/dev/null 2>&1; then
  die "linux/install-packages requires the C.UTF-8 locale"
fi

if ! command -v apt-get >/dev/null 2>&1; then
  die "apt-get is required"
fi

if ! command -v apt-cache >/dev/null 2>&1; then
  die "apt-cache is required"
fi

packages=(
  bat
  eza
  fd-find
  fzf
  gh
  git
  gnupg
  jq
  less
  ripgrep
  shellcheck
  shfmt
  vim
  zoxide
  zsh
  zsh-autosuggestions
  zsh-syntax-highlighting
)

LOCAL_BIN="$HOME/.local/bin"
DOCKER_BIN="/usr/bin/docker"
ZSH_SITE_FUNCTIONS="$HOME/.local/share/zsh/site-functions"
DOCKER_COMPLETION="$ZSH_SITE_FUNCTIONS/_docker"

validate_directory_destination() {
  local directory="$1"
  local existing_path="$directory"

  while [[ ! -e "$existing_path" && ! -L "$existing_path" ]]; do
    existing_path="$(dirname "$existing_path")"
  done

  if [[ -L "$existing_path" || ! -d "$existing_path" || ! -w "$existing_path" ]]; then
    die "directory path must resolve through writable regular directories: $directory"
  fi
}

validate_command_alias() {
  local link_path="$1"
  local expected_target="$2"
  local actual_target

  if [[ -L "$link_path" ]]; then
    actual_target="$(readlink "$link_path")"

    if [[ "$actual_target" != "$expected_target" ]]; then
      die "command alias must point exactly to $expected_target: $link_path"
    fi
  elif [[ -e "$link_path" ]]; then
    die "command alias must be absent or a canonical symlink: $link_path"
  fi
}

validate_command_alias "$LOCAL_BIN/bat" /usr/bin/batcat
validate_command_alias "$LOCAL_BIN/fd" /usr/bin/fdfind
validate_directory_destination "$LOCAL_BIN"

if [[ -L "$DOCKER_BIN" && ! -e "$DOCKER_BIN" ]]; then
  die "Docker command is dangling: $DOCKER_BIN"
fi

if [[ -e "$DOCKER_BIN" && (! -f "$DOCKER_BIN" || ! -x "$DOCKER_BIN") ]]; then
  die "Docker command is not an executable file: $DOCKER_BIN"
fi

if [[ -x "$DOCKER_BIN" ]]; then
  validate_directory_destination "$ZSH_SITE_FUNCTIONS"

  if [[ -L "$DOCKER_COMPLETION" || (-e "$DOCKER_COMPLETION" && ! -f "$DOCKER_COMPLETION") ]]; then
    die "Docker completion must be absent or a regular file: $DOCKER_COMPLETION"
  fi
fi

apt_get=(apt-get)

if [[ "$EUID" -ne 0 ]]; then
  if ! command -v sudo >/dev/null 2>&1; then
    die "sudo is required for non-root installs"
  fi

  echo "Authenticating sudo..."
  sudo -v
  apt_get=(sudo apt-get)
fi

echo "Updating apt package metadata..."
"${apt_get[@]}" update

missing_packages=()

for package in "${packages[@]}"; do
  if ! apt-cache show "$package" >/dev/null 2>&1; then
    missing_packages+=("$package")
  fi
done

if [[ "${#missing_packages[@]}" -ne 0 ]]; then
  printf 'error: required apt packages are unavailable:\n' >&2
  printf '  - %s\n' "${missing_packages[@]}" >&2
  exit 1
fi

echo "Installing Linux packages..."
"${apt_get[@]}" install -y "${packages[@]}"

if [[ ! -x /usr/bin/batcat ]]; then
  die "bat did not install the expected command: /usr/bin/batcat"
fi

if [[ ! -x /usr/bin/fdfind ]]; then
  die "fd-find did not install the expected command: /usr/bin/fdfind"
fi

mkdir -p "$LOCAL_BIN"

if [[ ! -L "$LOCAL_BIN/bat" ]]; then
  ln -s /usr/bin/batcat "$LOCAL_BIN/bat"
fi

if [[ ! -L "$LOCAL_BIN/fd" ]]; then
  ln -s /usr/bin/fdfind "$LOCAL_BIN/fd"
fi

required_shell_files=(
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
  /usr/share/doc/fzf/examples/completion.zsh
  /usr/share/doc/fzf/examples/key-bindings.zsh
  /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
)

for shell_file in "${required_shell_files[@]}"; do
  if [[ ! -r "$shell_file" ]]; then
    die "package installation did not provide required shell file: $shell_file"
  fi
done

if [[ -x "$DOCKER_BIN" ]]; then
  echo "Installing Docker zsh completions..."
  mkdir -p "$ZSH_SITE_FUNCTIONS"
  completion_file="$(mktemp "$ZSH_SITE_FUNCTIONS/.docker.XXXXXX")"
  trap 'rm -f "$completion_file"' EXIT

  if ! "$DOCKER_BIN" completion zsh >"$completion_file"; then
    die "Docker zsh completion generation failed"
  fi

  if [[ ! -s "$completion_file" ]]; then
    die "Docker generated an empty zsh completion"
  fi

  chmod 0644 "$completion_file"
  mv -f "$completion_file" "$DOCKER_COMPLETION"
  completion_file=""
  trap - EXIT
fi
