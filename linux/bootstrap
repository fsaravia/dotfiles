#!/usr/bin/env bash

set -euo pipefail
umask 077

if [[ "$#" -ne 0 ]]; then
  printf 'usage: %s\n' "$0"
  exit 1
fi

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKUP_ROOT="$HOME/.dotfiles-backups"
BACKUP_DIR="$BACKUP_ROOT/$(date +"%Y%m%d-%H%M%S")"
MACHINE_GIT_CONFIG="$HOME/.gitconfig"
GIT_BIN="/usr/bin/git"
ZSH_BIN="/usr/bin/zsh"
CHSH_BIN="/usr/bin/chsh"
MISSING_SIGNING_KEY="0000000000000000000000000000000000000000!"

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "linux/bootstrap only supports Linux"
  exit 1
fi

if [[ -n "${SUDO_USER:-}" ]]; then
  echo "linux/bootstrap must be run directly, not through sudo"
  exit 1
fi

if [[ ! -r /etc/os-release ]]; then
  echo "linux/bootstrap requires /etc/os-release"
  exit 1
fi

# shellcheck source=/dev/null
source /etc/os-release

case "${ID:-}:${VERSION_ID:-}" in
  debian:13 | ubuntu:24.04 | ubuntu:26.04) ;;
  *)
    echo "linux/bootstrap supports Debian 13 and Ubuntu 24.04 or 26.04"
    exit 1
    ;;
esac

if ! LC_ALL=C.UTF-8 /usr/bin/locale charmap >/dev/null 2>&1; then
  echo "linux/bootstrap requires the C.UTF-8 locale"
  exit 1
fi

links=(
  "$ROOT_DIR/linux/git/config:$HOME/.config/git/config"
  "$ROOT_DIR/git/ignore:$HOME/.config/git/ignore"
  "$ROOT_DIR/linux/.zshrc:$HOME/.zshrc"
  "$ROOT_DIR/.vimrc:$HOME/.vimrc"
)

backup_required=false

for entry in "${links[@]}"; do
  source_path="${entry%%:*}"
  destination="${entry#*:}"

  if [[ ! -e "$source_path" ]]; then
    printf 'required source is missing: %s\n' "$source_path"
    exit 1
  fi

  if [[ -e "$destination" && ! -L "$destination" && ! -f "$destination" && ! -d "$destination" ]]; then
    printf 'unsupported destination type: %s\n' "$destination"
    exit 1
  fi

  destination_parent="$(dirname "$destination")"

  while [[ ! -e "$destination_parent" && ! -L "$destination_parent" ]]; do
    destination_parent="$(dirname "$destination_parent")"
  done

  if [[ ! -d "$destination_parent" || ! -w "$destination_parent" ]]; then
    printf 'destination parent is not a writable directory: %s\n' "$destination_parent"
    exit 1
  fi

  if [[ -L "$destination" ]]; then
    if [[ "$(readlink "$destination")" != "$source_path" ]]; then
      backup_required=true
    fi
  elif [[ -e "$destination" ]]; then
    backup_required=true
  fi
done

if [[ -L "$BACKUP_ROOT" || (-e "$BACKUP_ROOT" && ! -d "$BACKUP_ROOT") ]]; then
  printf '%s must be a regular directory, not a symlink or special file\n' "$BACKUP_ROOT"
  exit 1
fi

if [[ -d "$BACKUP_ROOT" && ! -w "$BACKUP_ROOT" ]]; then
  printf 'backup directory is not writable: %s\n' "$BACKUP_ROOT"
  exit 1
fi

if [[ -d "$BACKUP_ROOT" && ! -O "$BACKUP_ROOT" ]]; then
  printf 'backup directory must be owned by the current user: %s\n' "$BACKUP_ROOT"
  exit 1
fi

if [[ "$backup_required" == true && (-e "$BACKUP_DIR" || -L "$BACKUP_DIR") ]]; then
  printf 'backup destination already exists: %s\n' "$BACKUP_DIR"
  exit 1
fi

if [[ -L "$MACHINE_GIT_CONFIG" || (-e "$MACHINE_GIT_CONFIG" && ! -f "$MACHINE_GIT_CONFIG") ]]; then
  printf '%s must be a regular file, not a symlink or special file\n' "$MACHINE_GIT_CONFIG"
  exit 1
fi

if [[ -f "$MACHINE_GIT_CONFIG" && ! -O "$MACHINE_GIT_CONFIG" ]]; then
  printf '%s must be owned by the current user\n' "$MACHINE_GIT_CONFIG"
  exit 1
fi

if [[ ! -x "$GIT_BIN" ]]; then
  printf 'linux/bootstrap requires %s\n' "$GIT_BIN"
  exit 1
fi

if [[ -f "$MACHINE_GIT_CONFIG" ]]; then
  if ! machine_git_keys="$("$GIT_BIN" config --file "$MACHINE_GIT_CONFIG" --name-only --list)"; then
    printf 'could not parse %s\n' "$MACHINE_GIT_CONFIG"
    exit 1
  fi

  signing_key_count=0

  while IFS= read -r key; do
    if [[ -n "$key" && "$key" != "user.signingkey" ]]; then
      printf '%s may contain only user.signingkey\n' "$MACHINE_GIT_CONFIG"
      exit 1
    fi

    if [[ "$key" == "user.signingkey" ]]; then
      ((signing_key_count += 1))
    fi
  done <<<"$machine_git_keys"

  if [[ "$signing_key_count" -ne 1 ]] || ! signing_key="$("$GIT_BIN" config --file "$MACHINE_GIT_CONFIG" --get user.signingkey)" || [[ -z "$signing_key" ]]; then
    printf '%s must contain exactly one nonempty user.signingkey\n' "$MACHINE_GIT_CONFIG"
    exit 1
  fi
fi

if [[ ! -x "$ZSH_BIN" ]]; then
  printf 'linux/bootstrap requires %s\n' "$ZSH_BIN"
  exit 1
fi

user_name="$(id -un)"

if ! passwd_entry="$(getent passwd "$user_name")"; then
  printf 'could not read the passwd entry for %s\n' "$user_name"
  exit 1
fi

current_shell="${passwd_entry##*:}"

if [[ "$current_shell" != "$ZSH_BIN" ]]; then
  if [[ ! -x "$CHSH_BIN" ]]; then
    printf 'linux/bootstrap requires %s\n' "$CHSH_BIN"
    exit 1
  fi

  if [[ ! -r /etc/shells ]] || ! grep -Fxq "$ZSH_BIN" /etc/shells; then
    printf '%s is not registered in /etc/shells\n' "$ZSH_BIN"
    exit 1
  fi
fi

backup_path() {
  local destination="$1"
  local relative_path="${destination#"$HOME"/}"
  local backup_destination="$BACKUP_DIR/$relative_path"

  mkdir -p "$(dirname "$backup_destination")"
  mv "$destination" "$backup_destination"
  printf 'backed up %s to %s\n' "$destination" "$backup_destination"
}

link_path() {
  local source="$1"
  local destination="$2"
  local current_target

  mkdir -p "$(dirname "$destination")"

  if [[ -L "$destination" ]]; then
    current_target="$(readlink "$destination")"

    if [[ "$current_target" == "$source" ]]; then
      printf 'already linked %s -> %s\n' "$destination" "$source"
      return
    fi

    backup_path "$destination"
  elif [[ -e "$destination" ]]; then
    backup_path "$destination"
  fi

  ln -s "$source" "$destination"
  printf 'linked %s -> %s\n' "$destination" "$source"
}

if [[ "$backup_required" == true ]]; then
  if [[ -d "$BACKUP_ROOT" ]]; then
    chmod 700 "$BACKUP_ROOT"
  else
    mkdir -m 700 "$BACKUP_ROOT"
  fi

  mkdir -m 700 "$BACKUP_DIR"
fi

if [[ -f "$MACHINE_GIT_CONFIG" ]]; then
  chmod 600 "$MACHINE_GIT_CONFIG"
else
  printf '[user]\n\tsigningkey = %s\n' "$MISSING_SIGNING_KEY" >"$MACHINE_GIT_CONFIG"
  chmod 600 "$MACHINE_GIT_CONFIG"
fi

for entry in "${links[@]}"; do
  link_path "${entry%%:*}" "${entry#*:}"
done

if [[ "$current_shell" != "$ZSH_BIN" ]]; then
  "$CHSH_BIN" -s "$ZSH_BIN"

  printf 'set login shell for %s to %s\n' "$user_name" "$ZSH_BIN"
fi
