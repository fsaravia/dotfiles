#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKUP_DIR="$HOME/.dotfiles-backups/$(date +"%Y%m%d-%H%M%S")"

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "linux/bootstrap only supports Linux"
  exit 1
fi

links=(
  "$ROOT_DIR/linux/git/config:$HOME/.config/git/config"
  "$ROOT_DIR/git/ignore:$HOME/.config/git/ignore"
  "$ROOT_DIR/linux/.zshrc:$HOME/.zshrc"
  "$ROOT_DIR/.vimrc:$HOME/.vimrc"
)

backup_path() {
  local destination="$1"

  mkdir -p "$BACKUP_DIR"
  mv "$destination" "$BACKUP_DIR/$(basename "$destination")"
  printf 'backed up %s to %s\n' "$destination" "$BACKUP_DIR"
}

link_path() {
  local source="$1"
  local destination="$2"

  mkdir -p "$(dirname "$destination")"

  if [[ -e "$destination" && ! -L "$destination" ]]; then
    backup_path "$destination"
  fi

  ln -sfn "$source" "$destination"
  printf 'linked %s -> %s\n' "$destination" "$source"
}

for entry in "${links[@]}"; do
  link_path "${entry%%:*}" "${entry#*:}"
done

if ! zsh_path="$(command -v zsh)"; then
  echo "warning: could not set zsh as the login shell; zsh is not installed"
  exit 0
fi

user_name="$(id -un)"
current_shell="$(getent passwd "$user_name" | cut -d: -f7)"

if [[ "$current_shell" != "$zsh_path" ]]; then
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    usermod --shell "$zsh_path" "$user_name"
  elif sudo -n true 2>/dev/null; then
    sudo -n usermod --shell "$zsh_path" "$user_name"
  else
    echo "warning: could not set zsh as the login shell; root or passwordless sudo is required"
    exit 0
  fi

  printf 'set login shell for %s to %s\n' "$user_name" "$zsh_path"
fi
