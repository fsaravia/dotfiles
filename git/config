[user]
	name = Federico Saravia
	email = fedesaravia@gmail.com

[push]
	default = simple

[color]
	ui = true

[core]
	pager = delta

[fetch]
	prune = true

[alias]
	st = status
	ci = commit
	br = branch
	co = checkout
	df = diff
	lg = log -p
	ll = log --graph --pretty=format:'%C(cyan)%h%Creset -%C(yellow)%d%Creset %s - %C(yellow)%aN%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
	f  = fetch --prune
	changelog = log --abbrev-commit --pretty=format:'- %h - %s - %aN'
	graph = log --graph --decorate --oneline --all

[commit]
	gpgsign = true
[delta]
	navigate = true
[interactive]
	diffFilter = delta --color-only
[init]
	defaultBranch = main
[merge]
	conflictstyle = zdiff3
[pager]
	branch = false
[pull]
	ff = only
[rerere]
	enabled = true
[include]
	path = ~/.config/git/config.local
